<nav>
  <a href="/users" class="btn btn-secondary">⬅️ Voltar</a>
</nav>

<div class="form-container">
  <h2 style="margin-bottom: 30px;">✏️ Editar Usuário</h2>

  <% if (error) { %>
    <div class="alert alert-danger">
      ❌ <%= error %>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="alert alert-success">
      ✅ <%= success %>
    </div>
  <% } %>

  <% if (user) { %>
    <form method="POST" action="/users/<%= user._id %>">
      <div class="form-group">
        <label for="name">Nome Completo</label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          placeholder="Digite o nome completo"
          value="<%= user.name %>"
        >
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          placeholder="Digite o email"
          value="<%= user.email %>"
        >
      </div>

      <div class="form-group">
        <label for="password">Nova Senha (deixe em branco para manter a atual)</label>
        <input 
          type="password" 
          id="password" 
          name="password" 
          placeholder="Digite a nova senha (opcional)"
          minlength="6"
        >
      </div>

      <div style="display: flex; gap: 10px;">
        <button type="submit" class="btn btn-success" style="flex: 1;">💾 Salvar Alterações</button>
        <a href="/users" class="btn btn-secondary" style="flex: 1; text-align: center;">❌ Cancelar</a>
      </div>
    </form>

    <div style="margin-top: 30px; padding-top: 30px; border-top: 2px solid #eee;">
      <h3 style="color: #dc3545; margin-bottom: 15px;">⚠️ Zona de Perigo</h3>
      <p style="color: #666; margin-bottom: 15px;">Esta ação é irreversível</p>
      <form method="POST" action="/users/delete/<%= user._id %>" style="display: inline;">
        <button type="submit" class="btn btn-danger" onclick="return confirm('Tem certeza que deseja DELETAR este usuário? Esta ação não pode ser desfeita!')">🗑️ Deletar Usuário</button>
      </form>
    </div>
  <% } else { %>
    <div class="alert alert-danger">
      ❌ Usuário não encontrado
    </div>
  <% } %>
</div>
